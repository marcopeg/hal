  "context": {
    "custom": "-- global custom context --"
  },
  "projects": {
    "obsidian": {
      "cwd": "./obsidian",
      "active": true,
      "engine": {
        "name": "copilot",
        "codex": {
          "networkAccess": true,
          "fullDiskAccess": true
        }
      },
      "telegram": {
        "botToken": "${OBSIDIAN_TELEGRAM_TOKEN}"
      },
      "context": {
        "secondCustom": "-- first custom --",
        "thirdCustom": "-- second custom --"
      },
      "commands": {
        "start": {
          "session": {
            "reset": true
          },
          "message": {
            "from": ".hal/WELCOME.md"
          }
        },
        "reset": {
          "session": {
            "reset": true
          },
          "message": {
            "confirm": "Reset totally?",
            "done": "All done!"
          }
        },
        "git": {
          "enabled": true
        },
        "model": {
          "enabled": true
        }
      }
    },
    "timetracker": {
      "cwd": "./timetracker",
      "telegram": {
        "botToken": "${TIMETRACKER_TELEGRAM_TOKEN}"
      },
      "engine": {
        "name": "cursor"
      }
    }
  }
}