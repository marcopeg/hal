# Fallback in case you don't waht to use the .claude/settings.json for env vars 
# (but you can use both, settings.json takes precedence over .env)
export ANTHROPIC_BASE_URL=https://openrouter.ai/api
export ANTHROPIC_API_KEY=""

# OpenRouter API key — get yours at https://openrouter.ai/keys
# Copy this file to .env and fill in your key (never commit .env)
export ANTHROPIC_AUTH_TOKEN=sk-or-v1-xxxxx
